/**
 * Core Philosophy: This ruleset enforces a user-centric security model.
 * Users have full control over their own data in the /users/{userId} path,
 * but cannot access data belonging to other users. A special rule allows
 * an "Admin" user to read all user data for management purposes.
 *
 * Data Structure:
 * - /users/{userId}: Private user-specific data. Admins can read this collection.
 * - /trends, /countries, etc.: Publicly accessible data.
 *
 * Key Security Decisions:
 * - User Data Privacy: Users can only read and write to their own document
 *   within the /users collection, identified by their UID.
 * - Admin Access: A user whose own document has `name == 'Admin'` is granted
 *   permission to list all documents in the /users collection.
 * - Public Read Access: Collections like 'trends' remain publicly readable.
 * - Client Writes Disabled (for public data): To maintain data integrity,
 *   all client-side write permissions on public collections are denied.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check if the requesting user is an admin.
    // An admin is a user whose document in the 'users' collection has the name 'Admin'.
    function isAdmin() {
      return request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.name == 'Admin';
    }

    /**
     * @description Controls access to user-specific data. Allows a user to read/write
     *              their own document. Grants list (read all) permissions to admins.
     * @path        /users/{userId}
     * @allow       read, write: A signed-in user can access their own document.
     * @allow       list: An admin user can read the entire collection.
     * @deny        A non-admin user cannot list the collection.
     * @principle   Enforces user data privacy while enabling admin functionality.
     */
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      allow list: if isAdmin();

      match /drafts/{draftId} {
        allow read, list, create, update, delete: if request.auth != null && request.auth.uid == userId;
      }

      match /transactions/{transactionId} {
        allow read, list, create, update, delete: if request.auth != null && request.auth.uid == userId;
      }
    }
    
    /**
     * @description Controls access to the 'auctions' collection. Allows public read
     *              access. Authenticated users can create and update auctions.
     * @path        /auctions/{auctionId}
     */
    match /auctions/{auctionId} {
      allow get, list: if true;
      allow create, update: if request.auth != null;
    }

    /**
     * @description Controls access to the 'trends' collection. Allows public
     *              read access but completely denies any client-side writes.
     * @path        /trends/{trendId}
     */
    match /trends/{trendId} {
      allow get, list: if true;
      allow create, update, delete: if false;
    }

    /**
     * @description Controls access to the 'countries' collection. Allows public
     *              read access but completely denies any client-side writes.
     * @path        /countries/{countryCode}
     */
    match /countries/{countryCode} {
      allow get, list: if true;
      allow create, update, delete: if false;
    }

    /**
     * @description Controls access to the 'ai_agents' collection. Allows public
     *              read access but completely denies any client-side writes.
     * @path        /ai_agents/{aiAgentId}
     */
    match /ai_agents/{aiAgentId} {
      allow get, list: if true;
      allow create, update, delete: if false;
    }

    /**
     * @description Controls access to the 'video_scripts' collection. Allows public
     *              read access but completely denies any client-side writes.
     * @path        /video_scripts/{videoScriptId}
     */
    match /video_scripts/{videoScriptId} {
      allow get, list: if true;
      allow create, update, delete: if false;
    }
  }
}
